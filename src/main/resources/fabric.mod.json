{
  "schemaVersion": 1,
  "id": "murdercraft",
  "version": "${version}",
  "name": "MurderCraft",
  "description": "A multiplayer mod inspired by the Murder game mode designed by Squeezie & Theodore Bonnet (itself inspired by Garry's Mod Murder). 2 hidden murderers, 1 armed detective, innocents trying to survive. Find the hidden pistol to turn the tide!",
  "authors": [
    "Remilulz_91"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/murdercraft",
    "sources": "https://github.com/Remilulz91/MurderCraft",
    "issues": "https://github.com/Remilulz91/MurderCraft/issues"
  },
  "license": "MIT",
  "icon": "assets/murdercraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "fr.murdercraft.MurderCraft"
    ],
    "client": [
      "fr.murdercraft.client.MurderCraftClient"
    ],
    "modmenu": [
      "fr.murdercraft.client.config.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "java": ">=21"
  },
  "recommends": {
    "cloth-config": "*",
    "modmenu": "*"
  }
}
